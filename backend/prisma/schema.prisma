generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String
  avatar      String?
  googleId    String?   @unique
  cvText      String?   @db.Text

  sessions              Session[]
  subscription          Subscription?
  interviewSessions     InterviewSession[]
  trialCodeRedemptions  TrialCodeRedemption[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([googleId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime

  userAgent    String?
  ipAddress    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
}

enum SubscriptionStatus {
  EXPIRED
  PAID_TRIAL
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

model Subscription {
  id                    String             @id @default(uuid())
  userId                String             @unique
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  status                SubscriptionStatus @default(EXPIRED)
  planInterval          PlanInterval?

  stripeCustomerId      String?            @unique
  stripeSubscriptionId  String?            @unique
  stripePriceId         String?

  paidTrialStartedAt    DateTime?
  paidTrialEndsAt       DateTime?

  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?

  cancelledAt           DateTime?

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

model TrialCode {
  id          String   @id @default(uuid())
  code        String   @unique
  trialDays   Int
  maxUses     Int      // 0 = unlimited
  usedCount   Int      @default(0)
  active      Boolean  @default(true)

  redemptions TrialCodeRedemption[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
}

model TrialCodeRedemption {
  id          String   @id @default(uuid())
  trialCodeId String
  trialCode   TrialCode @relation(fields: [trialCodeId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  redeemedAt  DateTime @default(now())

  @@unique([trialCodeId, userId])
  @@index([userId])
}

enum QuestionCategory {
  INTRO
  EXPERIENCE
  BEHAVIORAL
  TECHNICAL
  SCENARIO
}

model InterviewSession {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobTitle         String
  jobDescription   String?  @db.Text
  cvText           String?  @db.Text
  experienceLevel  String?
  language         String?  @default("English")
  focusBalance     Int?
  questionCount    Int?
  aggregateScore   Int

  answers          InterviewAnswer[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model InterviewAnswer {
  id                  String   @id @default(uuid())
  interviewSessionId  String
  interviewSession    InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)

  questionIndex       Int
  questionText        String   @db.Text
  category            QuestionCategory?

  duration            Int?
  transcript          String?  @db.Text

  overallScore        Int?
  logicScore          Int?
  concisenessScore    Int?
  precisionScore      Int?

  expertCritique      String?  @db.Text
  demoAnswer          String?  @db.Text
  ceoDemoAnswer       String?  @db.Text
  demoLogicRoadmap    Json?
  answerFramework     Json?
  logicUpgrades       Json?

  createdAt           DateTime @default(now())

  @@index([interviewSessionId])
}
